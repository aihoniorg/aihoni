{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./secrets/play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      },
      "ios": {
        "appleId": "rbnkoirala@hotmail.com",
        "ascAppId": "TODO_APPLE_APP_ID",
        "appleTeamId": "TODO_APPLE_TEAM_ID"
      }
    },
    "preview": {
      "android": {
        "serviceAccountKeyPath": "./secrets/play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "rbnkoirala@hotmail.com",
        "ascAppId": "TODO_APPLE_APP_ID",
        "appleTeamId": "TODO_APPLE_TEAM_ID"
      }
    }
  }
}
